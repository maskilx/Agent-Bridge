# Agent Bridge — copy to .env.local (dev) or set in your host's dashboard (prod).
# See DEPLOYMENT.md for the full private-deployment guide.

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL of this deployment (used for OAuth redirects).
APP_URL=http://localhost:3001
# Optional: directory for the SQLite database (point at a persistent volume in prod).
# DATA_DIR=/data

# ── Google sign-in (the ONLY production authentication method) ───────────────
# OAuth 2.0 Client ID (type: Web application) from
# https://console.cloud.google.com/apis/credentials with redirect URI:
#   <APP_URL>/api/auth/google/callback
# REQUIRED in production: without it, production shows "sign-in unavailable"
# (there is no fallback). In local development (next dev) an email-only sign-in
# is offered instead — it does not verify email ownership and never works in
# production builds.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Layer 2: in-app email allowlist (AUTHORIZATION, not authentication) ──────
# Comma-separated emails allowed to use the app AFTER authenticating with
# Google. Checked at sign-in, on every session, and on API bearer tokens.
# Unset = open (dev only).
# ALLOWED_EMAILS=adi.maskil@gmail.com

# ── Layer 1: Cloudflare Access (edge gate) ───────────────────────────────────
# When both are set, the app itself rejects any request that doesn't carry a
# valid Cloudflare Access JWT — so even the direct origin URL shows nothing.
# CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
# CF_ACCESS_AUD=<Audience tag of your Access application>

# ── Development switches — NEVER set these in production ─────────────────────
# SHOW_SAMPLE_FOUNDERS=1          # one-click sample-founder logins (dev only; ignored in prod)
# DANGEROUSLY_ALLOW_DEV_LOGIN=1   # UNSAFE: re-enables email-only sign-in in production.
#                                 # Anyone who knows an allowlisted email could sign in.
