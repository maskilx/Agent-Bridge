# AgentBridge V1 — copy to .env.local (dev) or set in your host's dashboard (prod).
# See DEPLOYMENT.md for the full private-deployment guide.

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL of this deployment (used for OAuth redirects).
APP_URL=http://localhost:3001
# Optional: directory for the SQLite database (point at a persistent volume in prod).
# DATA_DIR=/data

# ── Google sign-in (the product login) ───────────────────────────────────────
# OAuth 2.0 Client ID (type: Web application) from
# https://console.cloud.google.com/apis/credentials with redirect URI:
#   <APP_URL>/api/auth/google/callback
# If left empty, the login page offers the private-alpha email sign-in instead.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Layer 2: in-app email allowlist ──────────────────────────────────────────
# Comma-separated emails allowed to sign in (and stay signed in). Unset = open (dev only).
# ALLOWED_EMAILS=adi.maskil@gmail.com

# ── Layer 1: Cloudflare Access (edge gate) ───────────────────────────────────
# When both are set, the app itself rejects any request that doesn't carry a
# valid Cloudflare Access JWT — so even the direct origin URL shows nothing.
# CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
# CF_ACCESS_AUD=<Audience tag of your Access application>

# ── Dev/demo switches (leave unset in production) ────────────────────────────
# ALLOW_DEV_LOGIN=1        # show the email sign-in even when Google is configured
# SHOW_SAMPLE_FOUNDERS=1   # show seeded sample-founder logins on the login page
